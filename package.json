{
  "name": "blockchain-wasm",
  "version": "1.0.0",
  "description": "Biblioteca criptográfica de alto rendimiento: SHA-256, Keccak-256, ECDSA, Schnorr, ECDH, BIP-32 y más — compilada en AssemblyScript/WASM con un wrapper TypeScript.",
  "author": "Edison Manrique",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "assembly/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "asbuild": "asc assembly/index.ts --target release",
    "build:ts": "tsc",
    "build": "npm run asbuild && npm run build:ts",
    "examples": "node examples/server.cjs"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "cryptography",
    "sha256",
    "keccak256",
    "ecdsa",
    "schnorr",
    "bip32",
    "secp256k1",
    "bitcoin",
    "ethereum",
    "assemblyscript"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/edison-manrique/blockchain-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/edison-manrique/blockchain-wasm/issues"
  },
  "homepage": "https://github.com/edison-manrique/blockchain-wasm#readme"
}
